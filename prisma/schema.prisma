// Prisma-Schema: beschreibt alle Datenbank-Tabellen des Angebots-Tools.
// Datenbank ist Postgres (gehostet bei Supabase).

// Generator: erzeugt den Prisma-Client (Code zum Datenbankzugriff) nach src/generated/prisma
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Datenquelle: Postgres (Supabase). Die Verbindungs-URL fuers CLI (migrate/db push)
// steht in prisma.config.ts; die App verbindet sich zur Laufzeit ueber einen eigenen
// Adapter (src/lib/prisma.ts) mit DATABASE_URL (gepoolt).
datasource db {
  provider = "postgresql"
}

// Benutzerkonto fuer den Login (nur Miko und Nevio, keine offene Registrierung)
model User {
  id           String   @id @default(cuid()) // eindeutige ID
  username     String   @unique              // Login-Name (z. B. "miko")
  name         String                        // Anzeigename (z. B. "Miko Bruell")
  passwordHash String                        // Passwort NUR gehasht (bcrypt), nie Klartext
  createdAt    DateTime @default(now())      // Erstellzeitpunkt

  googleAccount GoogleAccount?               // verbundenes Google-Workspace-Konto (optional)

  sentChatMessages     ChatMessage[] @relation("SentChatMessages")     // vom Nutzer gesendete Chat-Nachrichten
  receivedChatMessages ChatMessage[] @relation("ReceivedChatMessages") // an den Nutzer gerichtete DM-Nachrichten
}

// Verbundenes Google-Konto fuer Gmail + Kalender (OAuth-Tokens).
// Wird angelegt, sobald ein Nutzer sein Google-Workspace-Konto verbindet.
model GoogleAccount {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email        String                        // verbundene Google-Adresse
  accessToken  String                        // kurzlebiges Zugriffs-Token
  refreshToken String   @default("")         // langlebiges Token zum Erneuern
  expiryDate   DateTime?                      // Ablaufzeitpunkt des accessToken
  scope        String   @default("")         // erteilte Berechtigungen
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Anfrage (Lead) – wird automatisch aus E-Mails der Kategorie "Anfrage" angelegt
// und durchlaeuft die Pipeline: neu -> angebot_erstellt -> angebot_gesendet -> gewonnen/verloren
model Lead {
  id            String    @id @default(cuid())
  mailId        String    @unique              // Gmail-Nachrichten-ID (verhindert Duplikate)
  fromName      String                          // Absendername
  fromEmail     String                          // Absenderadresse
  subject       String                          // Betreff der Anfrage
  snippet       String    @default("")          // Textauszug der Mail
  mailDate      DateTime                        // Datum der Mail
  status        String    @default("neu")       // neu | angebot_erstellt | angebot_gesendet | gewonnen | verloren | geloescht (Tombstone: ausgeblendet, verhindert Wieder-Anlage beim Mail-Sync)
  emailDraft    String    @default("")          // gespeicherter Mail-Vorschlag fuer den Versand
  sentAt        DateTime?                        // wann das Angebot verschickt wurde
  offerId       String?   @unique               // verknuepftes (automatisch erstelltes) Angebot
  offer         Offer?    @relation(fields: [offerId], references: [id], onDelete: SetNull)
  mailboxUserId String?                          // Dashboard-Nutzer, ueber dessen Google-Konto diese Mail einging
  mailboxEmail  String    @default("")           // die empfangende Adresse (z. B. info@lumio-agency.de), fuer Anzeige + Antwortversand
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Notiz zu einem durchgefuehrten Telefonat (Cold Call)
model CallNote {
  id        String   @id @default(cuid())
  company   String   @default("")            // angerufene Firma
  contact   String   @default("")            // Ansprechpartner
  phone     String   @default("")            // Telefonnummer
  outcome   String   @default("nicht_erreicht") // erreicht | nicht_erreicht | interesse | kein_interesse | termin
  notes     String   @default("")            // wie ist das Gespraech gelaufen
  nextStep  String   @default("")            // naechster Schritt (z. B. "Freitag erneut anrufen")
  createdAt DateTime @default(now())
}

// Akquise-Ziel ("Prospect") – ein Betrieb aus dem Lead-Gen-Tool, den wir
// kalt anrufen wollen. Wird vom leadgen-Runner in die DB gespuelt (Upsert
// ueber dedupKey) und im Bereich "Leads" abgearbeitet. Bewusst getrennt vom
// Modell `Lead` oben: `Lead` = EINGEHENDE Mail-Anfrage, `Prospect` = von uns
// AUSGEHENDE Akquise. Die Auto-Felder (Bewertung) aktualisiert jeder
// leadgen-Lauf; die manuellen CRM-Felder ruehrt der Sync nie an.
model Prospect {
  id        String   @id @default(cuid())
  dedupKey  String   @unique               // stabiler Firmen-Schluessel (dedup._schluessel) – verhindert Doppel ueber Laeufe

  // Stammdaten (auto)
  name      String                          // Firmenname
  branche   String   @default("")           // z. B. "heizung-sanitaer" (Kategorie im leadgen)
  telefon   String   @default("")
  adresse   String   @default("")
  plz       String   @default("")
  ort       String   @default("")
  website   String   @default("")

  // Bewertung (auto, jeder Lauf frischt sie auf)
  segment     String @default("")           // "1 – Heiß (keine Website)" …
  leadScore   Int    @default(0)            // hoeher = mehr Maengel = heisser Lead
  grund       String @default("")           // Hauptmangel
  designScore String @default("")           // KI-Design-Urteil 1–10 (leer, wenn ohne KI)
  aufhaenger  String @default("")           // fertiger Gespraechseinstieg

  // CRM / manuell (Sync fasst diese Felder NIE an)
  status         String    @default("neu")   // neu | kontaktiert | interesse | kein_interesse | termin | erledigt
  ansprechpartner String   @default("")
  kontaktiertAm  DateTime?                    // gesetzt beim Abhaken
  reaktion       String    @default("")
  wiedervorlage  DateTime?
  notiz          String    @default("")

  // Meta
  quellen        String    @default("")       // "gelbeseiten,google"
  zuerstGesehen  DateTime  @default(now())
  zuletztGesehen DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Verknuepfte Kontakt-Vorbereitung (optional, 1:1) — im Bereich Akquise
  contactPrep ContactPrep?

  @@index([branche, leadScore])
  @@index([status])
}

// Such-Auftrag: der "Suche starten"-Knopf im Dashboard legt so eine Zeile an
// (Status "angefragt"). Der leadgen-Runner (laeuft auf dem Mac/VPS) pollt
// diese Tabelle, fuehrt die Suche aus, schreibt Fortschritt zurueck und
// spuelt am Ende die Prospects ein. Vercel selbst fuehrt nichts aus.
model SearchRequest {
  id             String    @id @default(cuid())
  branche        String                        // eine Branche je Auftrag
  location       String                        // Ort oder PLZ
  radiusKm       Float     @default(15)
  quellen        String    @default("gelbeseiten,google,handwerk,branchenportale,social")
  limit          Int       @default(30)
  mitScreenshot  Boolean   @default(true)
  mitKi          Boolean   @default(true)
  verifyWebsites Boolean   @default(true)

  status       String    @default("angefragt") // angefragt | laeuft | fertig | fehler
  progress     String    @default("")           // letzte Fortschrittsmeldung des Runners
  resolvedOrte String    @default("")           // aufgeloeste Umkreis-Orte (kommagetrennt)
  newCount     Int?                             // neu hinzugekommene Prospects
  totalCount   Int?                             // Prospects der Branche danach insgesamt
  error        String    @default("")

  requestedBy String?                           // Username, der die Suche gestartet hat
  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?

  @@index([status])
}

// Einfacher Schluessel-Wert-Speicher fuer editierbare Texte (z. B. Telefon-Skript)
model AppText {
  id        String   @id                     // z. B. "telefon-skript"
  value     String   @default("")
  updatedAt DateTime @updatedAt
}

// Gemeinsame To-Do-Liste (fuer alle Dashboard-Nutzer sichtbar)
model Todo {
  id        String   @id @default(cuid())
  text      String
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Offener Auftrag / Projekt (voll funktionsfaehig, in der Datenbank gespeichert)
model Order {
  id           String    @id @default(cuid())
  title        String                         // Kurztitel des Auftrags
  customerName String    @default("")         // Kunde
  description  String    @default("")         // Beschreibung / Notizen
  status       String    @default("offen")    // offen | in_arbeit | wartet | erledigt
  priority     String    @default("normal")   // niedrig | normal | hoch
  value        Float     @default(0)          // Auftragswert netto (optional)
  progress     Int       @default(0)          // Fortschritt 0–100 %
  dueDate      DateTime?                       // Frist (optional)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// Paket / Leistungsposition – editierbar im Tool, NICHT im Code hart codiert
model Package {
  id           String   @id @default(cuid())
  name         String                        // z. B. "Landingpage (1 Seite)"
  description  String   @default("")         // Kurzbeschreibung
  defaultPrice Float    @default(0)          // Standard-Einzelpreis netto in Euro
  active       Boolean  @default(true)       // Inaktive Pakete tauchen im Formular nicht auf
  sortOrder    Int      @default(0)          // Reihenfolge in der Liste
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Ein erstelltes Angebot (Kopf-Daten + Kunde) – bildet den Verlauf
model Offer {
  id              String   @id @default(cuid())
  number          String   @unique           // Angebotsnummer, z. B. ANG-2026-001
  date            DateTime @default(now())    // Angebotsdatum
  validUntil      DateTime                    // "gueltig bis" als konkretes Datum

  // Kundendaten (Empfaenger des Angebots)
  customerCompany String                      // Firmen- oder Personenname (Pflicht)
  customerContact String   @default("")       // Ansprechpartner
  customerStreet  String   @default("")       // Strasse + Hausnummer
  customerZip     String   @default("")       // PLZ
  customerCity    String   @default("")       // Ort
  customerEmail   String   @default("")       // E-Mail (optional)
  customerPhone   String   @default("")       // Telefon (optional)

  notes           String   @default("")       // optionales Freitext-Notizfeld fuers PDF
  total           Float    @default(0)         // berechnete Gesamtsumme netto
  status          String   @default("offen")   // offen | angenommen | abgelehnt

  items           OfferItem[]                  // die einzelnen Positionen
  lead            Lead?                        // Anfrage, aus der dieses Angebot entstand (falls automatisch)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Eine einzelne Position innerhalb eines Angebots
model OfferItem {
  id        String   @id @default(cuid())
  offerId   String                            // gehoert zu welchem Angebot
  offer     Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  position  Int                               // laufende Pos.-Nr. (1, 2, 3, ...)
  label     String                            // Bezeichnung der Leistung
  quantity  Float    @default(1)              // Menge
  unitPrice Float    @default(0)              // Einzelpreis netto (ggf. ueberschrieben)
  lineTotal Float    @default(0)              // Menge * Einzelpreis
  createdAt DateTime @default(now())
}

// Interner Chat zwischen den Dashboard-Nutzern.
// Bildet sowohl den gemeinsamen Team-Channel (scope="team") als auch
// 1:1-Direktnachrichten (scope="dm") in einer Tabelle ab.
model ChatMessage {
  id          String   @id @default(cuid())
  senderId    String                          // wer die Nachricht geschrieben hat
  sender      User     @relation("SentChatMessages", fields: [senderId], references: [id], onDelete: Cascade)
  scope       String                          // "team" (Channel) oder "dm" (Direktnachricht)
  recipientId String?                         // nur bei scope="dm" gesetzt: Empfaenger
  recipient   User?    @relation("ReceivedChatMessages", fields: [recipientId], references: [id], onDelete: Cascade)
  body        String                          // der Nachrichtentext
  createdAt   DateTime @default(now())        // Sendezeitpunkt

  @@index([scope, recipientId, senderId, createdAt])
}

// Kontakt-Vorbereitung (Bereich Akquise): pro Zielunternehmen eine Analyse +
// Kontaktplanung als Vorbereitung fuer Anruf/Mail. Entsteht meist aus einem
// Prospect (Lead-Liste), kann aber auch manuell angelegt werden. Firmen-/
// Kontaktdaten werden bewusst KOPIERT (nicht nur verknuepft), damit Eintraege
// unabhaengig vom Prospect bestehen bleiben.
model ContactPrep {
  id         String    @id @default(cuid())
  prospectId String?   @unique                 // Herkunft aus der Lead-Liste (optional, 1:1)
  prospect   Prospect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)

  // Firmen- + Kontaktdaten (aus Prospect kopiert oder manuell erfasst)
  firma           String                        // Firmenname (Pflicht)
  ort             String   @default("")
  telefon         String   @default("")
  email           String   @default("")         // Prospect hat keine Mail -> hier manuell ergaenzt
  website         String   @default("")
  ansprechpartner String   @default("")

  // Analyse / Planung
  websiteStatus       String @default("unbekannt") // keine | veraltet | okay | unbekannt
  websiteMaengel      String @default("")           // Freitext: was ist an der Website falsch/fehlt
  empfohleneLeistungen String @default("")          // kommagetrennte Leistungen (aus Paketen + frei)
  kanal               String @default("telefon")    // telefon | mail | beide (bevorzugter Erstkontakt)

  status  String @default("offen")                  // offen | vorbereitet | kontaktiert
  notiz   String @default("")                       // freie Notizen fuers Gespraech

  erstelltVon String?                               // Username, der die Vorbereitung angelegt hat
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}
